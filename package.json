    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-tabs": "^1.1.2",
    "@reduxjs/toolkit": "^2.5.0",
    "@stripe/react-stripe-js": "^3.1.1",
    "@stripe/stripe-js": "^5.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dd-trace": "^5.97.0",
    "express": "^4.21.0",
    "lucide-react": "^0.460.0",
    "next-themes": "^0.4.4",
    "pino": "^9.6.0",
    "pino-http": "^10.3.0",
    "prom-client": "^15.1.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.54.2",
    "react-redux": "^9.2.0",
    "react-router-dom": "^6.28.0",
    "socket.io-client": "^4.8.1",
    "sonner": "^1.7.1",
    "tailwind-merge": "^2.6.0",
    "web-vitals": "^4.2.4",
    "zod": "^3.24.1"
  },
  "scripts": {
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "frontend:dev": "vite",
    "frontend:build": "tsc -p tsconfig.app.json --noEmit && vite build",
    "frontend:analyze": "tsc -p tsconfig.app.json --noEmit && vite build",
    "frontend:preview": "vite preview",
    "openapi:export": "npm run openapi:export --prefix backend",
    "openapi:types": "npm run openapi:types --prefix backend && openapi-typescript shared/openapi/openapi.json -o src/types/openapi.generated.ts",
    "test": "npm run test:coverage",
    "test:unit": "jest --testMatch \"**/src/**/*.unit.test.ts\"",
    "test:integration": "cross-env JEST_INTEGRATION=1 jest --testMatch \"**/tests/**/*.integration.test.ts\" --runInBand",
    "test:coverage": "jest --coverage --runInBand",
    "test:e2e": "playwright test",
    "build": "tsc -p tsconfig.build.json",
    "backend:dev": "npm run dev --prefix backend",
    "backend:build": "npm run build --prefix backend",
    "audit": "npm audit --audit-level=moderate"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@playwright/test": "^1.49.0",
    "@tailwindcss/forms": "^0.5.9",
    "@tailwindcss/typography": "^0.5.15",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/supertest": "^6.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "cross-env": "^7.0.3",
    "eslint": "^9.15.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "jest": "^29.7.0",
    "openapi-typescript": "^7.13.0",
    "mongodb": "^6.10.0",
    "postcss": "^8.4.49",
    "prettier": "^3.3.3",
    "rollup-plugin-visualizer": "^5.14.0",
    "supertest": "^7.0.0",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "ts-jest": "^29.2.5",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.15.0",
    "vite": "^6.0.3"
  }
}
