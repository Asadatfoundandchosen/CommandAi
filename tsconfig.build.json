{
  "extends": "./tsconfig.node.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": "dist",
    "rootDir": "src",
    "declaration": true
  },
  "include": [
    "src/datadog.ts",
    "src/instrumentation.ts",
    "src/main.ts",
    "src/telemetry.ts",
    "src/__ci__/**/*.ts",
    "src/lib/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.test.ts",
    "**/*.unit.test.ts",
    "**/*.integration.test.ts",
    "**/*.spec.ts",
    "src/components"
  ]
}
