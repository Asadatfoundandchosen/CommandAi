# Vite dev server proxies /api to the Express backend (backend/ package).
VITE_API_PROXY_TARGET=http://localhost:3000

# Optional absolute API base for production builds (default: same origin).
# VITE_API_BASE_URL=https://api.example.com

# Socket.io (defaults to same origin — Vite proxies /socket.io to the API in dev)
# VITE_WS_URL=http://localhost:3000
