# Copy to `.env` in this directory (`backend/.env`). Never commit real secrets.

NODE_ENV=development
PORT=3000
# Staging/prod: SESSION_COOKIE_SECURE=true, FORCE_HTTPS_REDIRECT=true (default in those envs)
# HSTS_MAX_AGE_SECONDS=31536000
# Frontend origin for magic-link emails (POST /api/v1/auth/magic-link/send)
APP_URL=http://localhost:5173
# Public API URL for SAML entity ID + ACS and OIDC redirect URIs (defaults to http://localhost:PORT)
# API_PUBLIC_URL=https://api.yourdomain.com
# Platform SP credentials (PEM) — per-org overrides in PUT /api/v1/organization/saml
# SAML_SP_CERTIFICATE=
# SAML_SP_PRIVATE_KEY=
# OIDC: configure per-org via PUT /api/v1/organization/oidc (issuer_url, client_id, client_secret)
# Google issuer: https://accounts.google.com
# Microsoft issuer: https://login.microsoftonline.com/{tenant}/v2.0

MONGODB_URI=mongodb://127.0.0.1:27017/1commandai
# Staging/prod: use mongodb+srv:// (Atlas TLS). Driver sets tls: true for non-local URIs.
# Optional driver pool (defaults: 10 / 50). Lower max when scaling out replicas.
# MONGODB_MIN_POOL_SIZE=10
# MONGODB_MAX_POOL_SIZE=50
# Optional: read-only user, secondaryPreferred + maxStaleness for reports/exports (must not equal MONGODB_URI)
# MONGODB_ANALYTICS_URI=mongodb+srv://1commandai_analytics_read:SECRET@cluster/app_db?retryWrites=false&appName=1cmd-analytics
# MONGODB_ANALYTICS_MIN_POOL_SIZE=0
# MONGODB_ANALYTICS_MAX_POOL_SIZE=10
# MONGODB_ANALYTICS_MAX_STALENESS_SECONDS=90

# Optional: TimescaleDB on PostgreSQL 15 (signal_metrics hypertable). URI from Vault in prod.
# TIMESCALE_DATABASE_URL=postgresql://timescale_app:SECRET@host:5432/metrics?sslmode=require
# TIMESCALE_POOL_MIN=0
# TIMESCALE_POOL_MAX=20

# Optional: Amazon OpenSearch 2.x (audit log search). Endpoint from Terraform / Vault.
# OPENSEARCH_NODE=https://vpc-xxx.us-east-1.es.amazonaws.com
# OPENSEARCH_USERNAME=os_master
# OPENSEARCH_PASSWORD=from-vault

REDIS_URL=redis://127.0.0.1:6379
# Staging/prod: REDIS_URL must use rediss:// (TLS). See docs/runbooks/encryption-in-transit.md
# `standard` = ioredis Redis (single node). `cluster` = ioredis Cluster (ElastiCache cluster mode, Redis 7+).
# ElastiCache: set REDIS_MODE=cluster and use the **cluster configuration endpoint** in REDIS_URL, e.g.
#   rediss://:AUTH@clustercfg.xxx.xxx.use1.cache.amazonaws.com:6379
# (Include password from Vault or AWS; TLS uses rediss://)
REDIS_MODE=standard

# Minimum 32 characters each (Joi validation)
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars!!
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars!
# JWT auth (SEC-001a): access **15 min**, refresh **7 days**; payload **org_id**, **sub**, **role**, **jti**.
# POST /api/v1/auth/login → tokens; POST /api/v1/auth/magic-link/send + /magic-link/verify (passwordless, 15m one-time link).
# POST /api/v1/auth/refresh rotates pair (each refresh invalidates previous JTI in Redis).
# Reuse of a consumed refresh token invalidates all user refresh tokens and emits auth_refresh_token_reuse_total + structured logs.
# Token blacklist (Redis TTL until JWT exp): checked on every request via createAuthenticateJwt. POST /api/v1/auth/logout, revoke-all; password change revokes all user tokens.
# Passwords: Argon2id hashing (password.service.ts), zxcvbn strength score >= 3 on user create/update; never logged.
# Account lockout: 5 failed logins → progressive lock 1m/5m/15m/1h (lockout.service.ts); cleared on successful login.
# Auth sessions (Redis): device, IP, location, last_active; GET/DELETE /api/v1/auth/sessions (JWT). Default max 10 concurrent per user.
# AUTH_MAX_CONCURRENT_SESSIONS=10
# Tenant APIs: `Authorization: Bearer <accessToken>` → `authenticateJwt` + `tenantMiddleware` (`org_id` from JWT, never body).

# express-session signing (min 32 chars). Load from Vault in real deployments.
SESSION_SECRET=change-me-session-secret-min-32-chars!!
# `Secure` cookie: use true in staging/prod (HTTPS / TLS to browser). false for local http://
SESSION_COOKIE_SECURE=false
# strict | lax | none — SameSite prevents CSRF (strict recommended in prod)
SESSION_COOKIE_SAMESITE=strict
# Optional cookie Domain (e.g. .1command.ai). Leave unset for host-only cookies.
# COOKIE_DOMAIN=
# httpOnly refresh_token cookie + CSRF double-submit (see docs/COOKIE-POLICY.md)
# AUTH_REFRESH_IN_COOKIE=true
# AUTH_REFRESH_IN_RESPONSE_BODY=true
# CSRF_PROTECTION_ENABLED=true

# AES-256-GCM key for encrypting TOTP secrets at rest (min 32 chars). Load from Vault in prod.
MFA_ENCRYPTION_KEY=change-me-mfa-encryption-key-32b!!
# Field-level encryption (AES-256-GCM): 64 hex chars = 32 bytes. Required in staging/prod (Vault).
# Dev: omit to derive from MFA_ENCRYPTION_KEY (SHA-256). See docs/FIELD-ENCRYPTION.md
# FIELD_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
# MFA backup codes: 10 single-use (Argon2); GET /api/v1/auth/mfa/backup-codes; POST …/backup-codes/regenerate (TOTP required).
# Org MFA enforcement: GET/PUT /api/v1/organization/mfa-policy (org_admin); grace period; blocks tenant APIs after grace (403 mfa_enforcement).
# Daily reminder emails during grace: BullMQ mfa-policy-daily-reminder (08:30 UTC).

# Twilio SMS MFA (optional — all three required to enable). 6-digit codes, 5 min TTL, 3 SMS / 10 min per user.
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=+15005550006

# Sliding-window rate limits (Redis; fail open if Redis is down)
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_TENANT_WINDOW_SEC=60
# RATE_LIMIT_TENANT_MAX=1000
# RATE_LIMIT_USER_WINDOW_SEC=60
# RATE_LIMIT_USER_MAX=100
# RATE_LIMIT_ENDPOINT_WINDOW_SEC=60
# RATE_LIMIT_ENDPOINT_MAX=100
# RATE_LIMIT_EXPENSIVE_MAX=10

# GET response cache-aside (Redis). Path → TTL table in `cache.middleware.ts`.
# RESPONSE_CACHE_ENABLED=true

# Redis pub/sub + Socket.io bridge (server.ts uses `node:http` createServer).
# PUBSUB_ENABLED=true
# WEBSOCKET_ENABLED=true

# Optional: S3 bucket for **documents** / **exports** (Terraform `1commandai-files-<env>`, SSE-KMS, CRR in second region)
# S3_FILES_BUCKET=1commandai-files-dev
# S3_FILES_REGION=us-east-1
# S3_FILES_KMS_KEY_ARN=arn:aws:kms:us-east-1:ACCOUNT:key/KEYID
# Presigned URLs: POST /api/files/presign-upload | /api/files/presign-download (x-org-id + JSON body; 15m TTL, 100MB max, MIME whitelist)

# Optional: Bearer token for Bull Board at GET /admin/queues and for GET/DELETE /api/sessions (set to enable)
# QUEUE_ADMIN_TOKEN=
# QUEUE_METRICS_INTERVAL_MS=10000

# Bearer token for **Organization** CRUD (`Authorization: Bearer …`) — platform admin only. Optional; if unset, organization routes return 503 until configured.
# PLATFORM_ADMIN_TOKEN=

# Stripe billing (optional). Platform admin: POST /api/billing/stripe/catalog/sync, customer, subscription.
# Webhook: POST /api/billing/stripe/webhook (configure in Stripe Dashboard; use Stripe CLI locally).
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# Org admin credit packs: POST /api/v1/credits/purchase (enable payment_intent.succeeded in Stripe webhook)
# Low-balance alerts (25% / 10% / 5%): SendGrid email + in-app via Redis pub/sub
# SENDGRID_API_KEY=
# SENDGRID_FROM_EMAIL=alerts@yourdomain.com

# Hierarchy APIs: minimum role from JWT **role** claim (legacy fallback: **X-User-Role** header).
