{
  "name": "@1commandai/backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec \"node --import tsx/esm src/server.ts\"",
    "build": "tsc -p tsconfig.json && tsc-alias -p tsconfig.json",
    "start": "node dist/server.js",
    "test": "node --import tsx/esm --test src/modules/user/user.password.unit.test.ts src/common/middleware/tenant.middleware.unit.test.ts src/modules/audit/audit.service.test.ts src/modules/files/file.service.test.ts src/modules/organization/organization.status-rules.unit.test.ts src/common/validators/hierarchy.validator.integration.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "openapi:export": "node --import tsx/esm scripts/dump-openapi.ts",
    "openapi:types": "npm run openapi:export && openapi-typescript openapi.json -o src/types/openapi.generated.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1035.0",
    "@aws-sdk/s3-request-presigner": "^3.1035.0",
    "@bull-board/api": "^7.0.0",
    "@bull-board/express": "^7.0.0",
    "@opensearch-project/opensearch": "^2.12.0",
    "bullmq": "^5.75.2",
    "connect-redis": "^7.1.1",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.21.0",
    "express-session": "^1.19.0",
    "helmet": "^8.0.0",
    "inversify": "^8.1.0",
    "ioredis": "^5.10.1",
    "joi": "^18.1.2",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.5.0",
    "morgan": "^1.10.0",
    "pg": "^8.13.1",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "socket.io": "^4.8.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.19.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.9.0",
    "@types/pg": "^8.11.10",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "nodemon": "^3.1.7",
    "openapi-typescript": "^7.13.0",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.10",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20"
  }
}
